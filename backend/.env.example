# PostgreSQL connection (use ONE of the two approaches below)

# Option A – single connection string (preferred on Render + Supabase)
DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Option B – individual fields (only if you don't use DATABASE_URL)
DB_NAME=postgres
DB_USER=postgres.<project-ref>
DB_PASSWORD=<your-db-password>
DB_HOST=aws-0-<region>.pooler.supabase.com
DB_PORT=6543

# Auth
JWT_SECRET=<a-long-random-secret>

# CORS – set this to your Vercel frontend URL, e.g. https://expense-manager.vercel.app
ALLOWED_ORIGIN=https://your-frontend.vercel.app

# Set to 'false' only if connecting to a local Postgres without SSL
# DB_SSL=false
